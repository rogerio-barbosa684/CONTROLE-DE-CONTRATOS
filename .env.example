# SUPABASE - Criar em https://supabase.com
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=chave_service_role_aqui

# JWT_SECRET - Chave para assinar tokens (gerada automaticamente se vazia)
JWT_SECRET=

# Configuracoes de sessao
SESSION_TIMEOUT_HOURS=8

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu@email.com
EMAIL_PASS=sua_senha

# Admin password inicial
ADMIN_PASSWORD=ADMIN@IDEALALIMENTACAO
